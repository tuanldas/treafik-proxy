# Cấu hình theo service. traefik luôn bật; service khác bật bằng <TÊN>=true.
# Sửa xong chạy: ./setup.sh

# --- Chung ---
DOMAIN=localhost
TZ=Asia/Ho_Chi_Minh
PROXY_NETWORK=proxy
MONITORING_NETWORK=monitoring
PROMETHEUS_VOLUME=prometheus-data
GRAFANA_VOLUME=grafana-data

# --- traefik (bắt buộc) ---
TRAEFIK_VERSION=v3.7.5
SSL=false                       # true: Let's Encrypt | false: SSL ngoài (Cloudflare)
ACME_EMAIL=admin@example.com
TRAEFIK_DASHBOARD_USER=admin
TRAEFIK_DASHBOARD_PASSWORD=changeme   # mật khẩu thường, setup.sh tự hash

# --- grafana ---
GRAFANA=true
GRAFANA_VERSION=13.0.2
GRAFANA_USER=admin
GRAFANA_PASSWORD=changeme

# --- prometheus ---
PROMETHEUS=true
PROMETHEUS_VERSION=v3.12.0

# --- node-exporter (metric máy chủ) ---
NODE_EXPORTER=true
NODE_EXPORTER_VERSION=v1.11.1

# --- cadvisor (metric container) ---
CADVISOR=true
CADVISOR_VERSION=v0.55.1        # gcr.io cao nhất tới v0.55.1; mới hơn ở GHCR

# --- whoami (test) ---
WHOAMI=true

# ============================================================
# GIÁM SÁT NÂNG CAO (mặc định tắt — bật khi cần)
# ============================================================

# --- alertmanager (cảnh báo) ---
# Bật để gửi cảnh báo khi có sự cố. Chọn kênh bằng ALERT_* + điền secret.
# Hướng dẫn lấy token/webhook: docs/notification-channels-setup.md
ALERTMANAGER=false
ALERTMANAGER_VERSION=v0.33.0
# Kênh nhận — bật NHIỀU = nhận TRÙNG qua mọi kênh (broadcast, không phải failover):
ALERT_TELEGRAM=false
ALERT_SLACK=false
ALERT_EMAIL=false
ALERT_DISCORD=false
# Secret (để TRỐNG ở file mẫu — điền vào .env thật, đã gitignored):
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
SLACK_WEBHOOK_URL=
DISCORD_WEBHOOK_URL=
SMTP_SMARTHOST=
SMTP_FROM=
SMTP_TO=
SMTP_AUTH_USERNAME=
SMTP_AUTH_PASSWORD=

# --- blackbox-exporter (uptime + SSL) ---
# Probe từng domain Traefik route; target tự sinh từ Host() trong services.
BLACKBOX_EXPORTER=false
BLACKBOX_EXPORTER_VERSION=v0.28.0

# --- loki + alloy (log tập trung) ---
# Alloy thu log container -> Loki; xem trong Grafana (datasource Loki).
LOKI=false
LOKI_VERSION=3.7.2
ALLOY=false
ALLOY_VERSION=v1.17.0
