{
  "annotations": { "list": [] },
  "editable": true,
  "graphTooltip": 1,
  "schemaVersion": 39,
  "tags": ["containers", "cadvisor", "docker"],
  "title": "Containers / cAdvisor",
  "timezone": "browser",
  "time": { "from": "now-6h", "to": "now" },
  "refresh": "30s",
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "query": "prometheus",
        "current": { "text": "Prometheus", "value": "Prometheus" }
      }
    ]
  },
  "panels": [
    {
      "type": "stat",
      "title": "Số container đang chạy",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 4, "w": 8, "x": 0, "y": 0 },
      "targets": [
        { "expr": "count(count by (name) (container_last_seen{name!=\"\"}))", "legendFormat": "containers" }
      ]
    },
    {
      "type": "stat",
      "title": "Tổng CPU container (cores)",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 4, "w": 8, "x": 8, "y": 0 },
      "targets": [
        { "expr": "sum(rate(container_cpu_usage_seconds_total{name!=\"\"}[5m]))", "legendFormat": "cores" }
      ]
    },
    {
      "type": "stat",
      "title": "Tổng RAM container",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 4, "w": 8, "x": 16, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "bytes" } },
      "targets": [
        { "expr": "sum(container_memory_usage_bytes{name!=\"\"})", "legendFormat": "RAM" }
      ]
    },
    {
      "type": "timeseries",
      "title": "CPU theo container (cores)",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 4 },
      "targets": [
        { "expr": "sum by (name) (rate(container_cpu_usage_seconds_total{name!=\"\"}[5m]))", "legendFormat": "{{name}}" }
      ]
    },
    {
      "type": "timeseries",
      "title": "RAM theo container",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 4 },
      "fieldConfig": { "defaults": { "unit": "bytes" } },
      "targets": [
        { "expr": "sum by (name) (container_memory_usage_bytes{name!=\"\"})", "legendFormat": "{{name}}" }
      ]
    },
    {
      "type": "timeseries",
      "title": "Network nhận theo container (bytes/s)",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 13 },
      "fieldConfig": { "defaults": { "unit": "Bps" } },
      "targets": [
        { "expr": "sum by (name) (rate(container_network_receive_bytes_total{name!=\"\"}[5m]))", "legendFormat": "{{name}}" }
      ]
    },
    {
      "type": "timeseries",
      "title": "Network gửi theo container (bytes/s)",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 13 },
      "fieldConfig": { "defaults": { "unit": "Bps" } },
      "targets": [
        { "expr": "sum by (name) (rate(container_network_transmit_bytes_total{name!=\"\"}[5m]))", "legendFormat": "{{name}}" }
      ]
    }
  ]
}
